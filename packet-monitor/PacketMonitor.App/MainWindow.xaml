<Window x:Class="PacketMonitor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PacketMonitor.App"
        xmlns:vm="clr-namespace:PacketMonitor.App.ViewModels"
        mc:Ignorable="d"
        Title="Packet Monitor - 應用程式封包監控" Height="650" Width="1100">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 工具列：選擇目標程式與網卡 -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="目標程式：" VerticalAlignment="Center" Margin="0,0,4,0" />
            <ComboBox Width="240" ItemsSource="{Binding Processes}"
                      SelectedItem="{Binding SelectedProcess}" />
            <Button Content="重新整理" Command="{Binding RefreshProcessesCommand}" Margin="8,0,16,0" Padding="8,2" />

            <TextBlock Text="網卡：" VerticalAlignment="Center" Margin="0,0,4,0" />
            <ComboBox Width="280" ItemsSource="{Binding Devices}" DisplayMemberPath="Description"
                      SelectedItem="{Binding SelectedDevice}" />

            <Button Content="開始擷取" Command="{Binding StartCommand}" Margin="16,0,4,0" Padding="8,2" />
            <Button Content="停止" Command="{Binding StopCommand}" Padding="8,2" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="{Binding StatusText}" Margin="0,0,0,8" FontWeight="Bold" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- 封包列表 -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Packets}" SelectedItem="{Binding SelectedPacket}"
                      AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,8,0"
                      VirtualizingPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="時間" Binding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" Width="100" />
                    <DataGridTextColumn Header="方向" Binding="{Binding DirectionText}" Width="60" />
                    <DataGridTextColumn Header="協定" Binding="{Binding Protocol}" Width="50" />
                    <DataGridTextColumn Header="本機端點" Binding="{Binding LocalEndPoint}" Width="150" />
                    <DataGridTextColumn Header="遠端端點" Binding="{Binding RemoteEndPoint}" Width="150" />
                    <DataGridTextColumn Header="長度" Binding="{Binding Length}" Width="60" />
                    <DataGridTextColumn Header="程式" Binding="{Binding ProcessName}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- 封包內容檢視 -->
            <GroupBox Grid.Column="1" Header="封包內容">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <GroupBox Header="Hex" Grid.Row="0">
                        <TextBox Text="{Binding SelectedPacket.HexPreview, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas"
                                 VerticalScrollBarVisibility="Auto" AcceptsReturn="True" />
                    </GroupBox>
                    <GroupBox Header="ASCII" Grid.Row="1">
                        <TextBox Text="{Binding SelectedPacket.AsciiPreview, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas"
                                 VerticalScrollBarVisibility="Auto" AcceptsReturn="True" />
                    </GroupBox>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
